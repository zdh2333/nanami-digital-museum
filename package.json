{
  "name": "nanami-cat-museum",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile",
    "audit:assets": "node scripts/audit-public-assets.mjs",
    "archive:build": "node scripts/optimize-archive-assets.mjs",
    "share:build": "node scripts/build-share-assets.mjs"
  },
  "dependencies": {
    "framer-motion": "12.40.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.34.5"
  },
  "overrides": {
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.4.21",
    "exifr": "7.1.3",
    "jsdom": "25.0.1",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
