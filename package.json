{
  "name": "nanami-cat-museum",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dev:pages": "VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA npm run build && wrangler d1 migrations apply nanami-guestbook --local --persist-to .wrangler/state-e2e && wrangler pages dev dist --ip 127.0.0.1 --port 4173 --persist-to .wrangler/state-e2e --binding TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA --binding TURNSTILE_TEST_MODE=true --binding GUESTBOOK_HMAC_KEY=local-only-guestbook-test-key-2026",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:pages": "E2E_LOCAL_PAGES=1 playwright test --project=desktop",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile",
    "audit:assets": "node scripts/audit-public-assets.mjs",
    "archive:build": "node scripts/optimize-archive-assets.mjs",
    "share:build": "node scripts/build-share-assets.mjs"
  },
  "dependencies": {
    "framer-motion": "12.40.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.34.5"
  },
  "overrides": {
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260717.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.4.21",
    "exifr": "7.1.3",
    "jsdom": "25.0.1",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
